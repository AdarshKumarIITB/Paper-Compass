DATABASE_URL=postgresql+asyncpg://postgres:localdev@localhost:5432/papercompass
ANTHROPIC_API_KEY=sk-ant-...
GROBID_URL=http://localhost:8070
SEMANTIC_SCHOLAR_API_KEY=
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Session JWT (generate: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=
JWT_EXPIRY_HOURS=720
SESSION_COOKIE_NAME=pc_session
SESSION_COOKIE_SECURE=false

FRONTEND_URL=http://localhost:8080

PDF_STORAGE_DIR=./storage/pdfs
